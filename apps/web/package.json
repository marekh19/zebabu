{
  "name": "@zebabu/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest --run",
    "clean": "rm -rf .svelte-kit build node_modules",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "redis:studio": "redis-commander --redis-host localhost --redis-port 6379"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.13.0",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "bits-ui": "^2.16.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "formsnap": "^2.0.1",
    "globals": "^17.4.0",
    "redis-commander": "^0.9.0",
    "svelte": "^5.53.6",
    "svelte-check": "^4.4.4",
    "svelte-sonner": "^1.0.8",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@dnd-kit-svelte/svelte": "^0.1.6",
    "@dnd-kit/helpers": "^0.2.4",
    "@zebabu/emails": "workspace:*",
    "better-auth": "^1.5.0",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "nanoid": "^5.1.6",
    "narrowland": "^1.5.0",
    "postgres": "^3.4.8",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.0.0"
  }
}
