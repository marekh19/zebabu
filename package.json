{
  "name": "zebabu-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint:check": "turbo lint:check",
    "lint:fix": "turbo lint:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:start": "docker compose up -d",
    "db:push": "bun run --filter @zebabu/web db:push",
    "db:generate": "bun run --filter @zebabu/web db:generate",
    "db:migrate": "bun run --filter @zebabu/web db:migrate",
    "db:studio": "bun run --filter @zebabu/web db:studio",
    "redis:studio": "bun run --filter @zebabu/web redis:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.12"
  },
  "engines": {
    "bun": ">=1"
  },
  "engineStrict": true,
  "packageManager": "bun@1.3.13"
}
