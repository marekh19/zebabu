{
  "name": "zebabu-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean && rm -rf node_modules",
    "db:start": "docker compose up",
    "db:push": "pnpm --filter @zebabu/web db:push",
    "db:generate": "pnpm --filter @zebabu/web db:generate",
    "db:migrate": "pnpm --filter @zebabu/web db:migrate",
    "db:studio": "pnpm --filter @zebabu/web db:studio",
    "redis:studio": "pnpm --filter @zebabu/web redis:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.12"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "engineStrict": true,
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
