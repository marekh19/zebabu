{
  "name": "@zebabu/emails",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --format esm --target node && tsc --declaration --emitDeclarationOnly",
    "dev": "email dev -p 3001 --dir src/templates",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.11",
    "@types/node": "^25.3.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@zebabu/tsconfig": "workspace:*",
    "react-email": "^5.2.9",
    "typescript": "^5.9.3"
  }
}
